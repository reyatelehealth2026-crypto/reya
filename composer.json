{
    "name": "line-telepharmacy/platform",
    "description": "LINE Telepharmacy Platform",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "endroid/qr-code": "^4.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.40"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Classes\\": "classes/",
            "Modules\\": "modules/",
            "Tools\\": "tools/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "lint:fix": "php-cs-fixer fix",
        "analyse": "phpstan analyse classes/ app/ --level 0"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}